# Copy to .env.local and fill in values from Supabase / Vercel dashboards.
# Supabase: https://supabase.com/dashboard/project/lwupkuhygzybnkoaoenr/settings/api
# Vercel: Project Settings → Environment Variables

# ── Required: Supabase ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://lwupkuhygzybnkoaoenr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Required: App URLs ────────────────────────────────────────────────────────
# Local dev: both localhost. Production split:
#   Marketing  → https://eateryvn.com
#   App        → https://app.eateryvn.com
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Optional: Marketing blog (Google Sheets, no CMS) ─────────────────────────
# Tab name must be "Posts". See docs/marketing-site.md
BLOG_GOOGLE_SHEET_ID=

# ── Optional: Contact form destination ───────────────────────────────────────
CONTACT_EMAIL=hello@eateryvn.com

# ── Optional: Email (Resend) ─────────────────────────────────────────────────
# Without this, team invites log to the console instead of sending email.
RESEND_API_KEY=
NEXT_PUBLIC_SENDER_EMAIL=noreply@eateryvn.com

# ── Optional: PayOS payments ──────────────────────────────────────────────────
# Without these, PayOS uses dummy credentials (payments won't work).
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# ── Required for custom domains (platform setup — enables self-service for users) ─
# Create token: https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
# Only if the Vercel project belongs to a team:
VERCEL_TEAM_ID=
